<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Samy Chat</title>
    <style>
        body { background-color: #e7ebf0; margin: 0; font-family: sans-serif; display: flex; justify-content: center; }
        .chat-container { width: 100%; max-width: 600px; height: 100vh; padding: 15px; box-sizing: border-box; display: flex; flex-direction: column; gap: 8px; overflow-y: auto; background-image: url('https://user-images.githubusercontent.com/15075759/28719144-86dc0f70-73b1-11e7-911d-60d70fcded21.png'); }
        .bubble { max-width: 75%; padding: 8px 12px; border-radius: 12px; font-size: 14.5px; color: #000; box-shadow: 0 1px 1px rgba(0,0,0,0.1); word-wrap: break-word; position: relative; }
        .right { align-self: flex-end; background-color: #effdde; border-bottom-right-radius: 4px; }
        .left { align-self: flex-start; background-color: #ffffff; border-bottom-left-radius: 4px; }
        .bubble a { color: #00488d; text-decoration: none; font-weight: bold; }
        #error-log { color: red; background: white; padding: 10px; display: none; position: fixed; top: 0; z-index: 999; }
    </style>
</head>
<body>
    <div id="error-log"></div>
    <div id="chat" class="chat-container"></div>

    <script>
        function linkify(text) {
            const urlPattern = /(\b(https?|ftp|file):\/\/[-A-Z0-9+&@#\/%?=~_|!:,.;]*[-A-Z0-9+&@#\/%=~_|])/ig;
            const wwwPattern = /(^|[^\/])(www\.[\S]+(\b|$))/gim;
            return text.replace(urlPattern, '<a href="$1" target="_blank">$1</a>').replace(wwwPattern, '$1<a href="http://$2" target="_blank">$2</a>');
        }

        async function loadMessages() {
            const log = document.getElementById('error-log');
            try {
                const response = await fetch('./messages.json?t=' + Date.now());
                if (!response.ok) throw new Error("File messages.json not found in /chat/ folder.");
                
                const messages = await response.json();
                const chat = document.getElementById('chat');
                chat.innerHTML = ''; 

                messages.forEach(msg => {
                    const div = document.createElement('div');
                    div.className = `bubble ${msg.isMe ? 'right' : 'left'}`;
                    div.innerHTML = linkify(msg.text);
                    chat.appendChild(div);
                });
                chat.scrollTop = chat.scrollHeight;
            } catch (e) {
                log.style.display = 'block';
                log.innerHTML = "DEBUG ERROR: " + e.message;
            }
        }

        loadMessages();
        setInterval(loadMessages, 30000);
    </script>
</body>
</html>
